# TCS Admin — Environment Variables (Phase 2)
# Copy to .env.local and fill in values when connecting Supabase and integrations.

# API
NEXT_PUBLIC_API_URL=http://localhost:4000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth — must match tcs-api ADMIN_ORIGIN / MEMBER_AUTH_WEB_CALLBACK_URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# QR display URL (copy link shown in admin; QR image encodes raw shortCode)
NEXT_PUBLIC_QR_DISPLAY_BASE=https://techcatalystsummit.com/q

# E2E (optional overrides)
# E2E_ADMIN_EMAIL=admin1@tcs.dev
# E2E_ADMIN_PASSWORD=TcsDev2026!

# QR tracking (Dub.co)
DUB_API_KEY=

# Email (SendGrid or Resend)
SENDGRID_API_KEY=
# RESEND_API_KEY=

# Payments (Stripe)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
